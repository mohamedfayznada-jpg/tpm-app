{
  "rules": {
    "tpm_system": {
      ".read": "auth != null",
      
      "api_keys": { 
        ".write": "auth != null && root.child('tpm_system/users/' + auth.uid + '/role').val() === 'admin'" 
      },
      
      "departments": { 
        ".write": "auth != null && root.child('tpm_system/users/' + auth.uid + '/role').val() === 'admin'" 
      },
      
      "maintenanceEngineers": { 
        ".write": "auth != null && root.child('tpm_system/users/' + auth.uid + '/role').val() === 'admin'" 
      },
      
      "history": {
        ".write": "auth != null && (root.child('tpm_system/users/' + auth.uid + '/role').val() === 'admin' || root.child('tpm_system/users/' + auth.uid + '/role').val() === 'auditor')"
      },
      
      "tasks": { ".write": "auth != null" },
      "tags": { ".write": "auth != null" },
      "kaizenComments": { ".write": "auth != null" },
      "likes": { ".write": "auth != null" },
      
      "users": {
        ".read": "auth != null",
        "$uid": { 
          ".write": "auth != null && (auth.uid === $uid || root.child('tpm_system/users/' + auth.uid + '/role').val() === 'admin')" 
        }
      },
      
      "points": { ".write": "auth != null" },
      "logs": { ".write": "auth != null" }
    }
  }
}